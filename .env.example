# ============================================================
# Content Factory — шаблон переменных окружения
#
# КАК ИСПОЛЬЗОВАТЬ:
#   1. Скопируй этот файл: cp .env.example .env
#   2. Заполни .env своими реальными значениями
#   3. НИКОГДА не коммить .env в git!
# ============================================================


# ------------------------------------------------------------
# TELEGRAM BOT (для постинга и алёртов)
# Получить: https://t.me/BotFather → /newbot
# ------------------------------------------------------------
BOT_TOKEN=your_telegram_bot_token_here

# Твой личный Telegram ID (для получения алёртов)
# Узнать: написать боту @userinfobot
ADMIN_CHAT_ID=your_telegram_user_id_here


# ------------------------------------------------------------
# TELEGRAM USER API (для мониторинга рекламы через Telethon)
# Получить: https://my.telegram.org → API development tools
# ------------------------------------------------------------
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
# Номер телефона аккаунта для мониторинга (формат: +79001234567)
TELEGRAM_PHONE=+7XXXXXXXXXX


# ------------------------------------------------------------
# КАРТИНКИ ДЛЯ ПОСТОВ (необязательно — посты выйдут и без картинок)
# Unsplash: https://unsplash.com/developers → New Application → Access Key
# Pexels:   https://www.pexels.com/api/ → Your API Key
# ------------------------------------------------------------
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=


# ------------------------------------------------------------
# ANTHROPIC CLAUDE API (для генерации контента)
# Получить: https://console.anthropic.com → API Keys
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Модель для генерации (можно менять)
CLAUDE_MODEL=claude-sonnet-4-5


# ------------------------------------------------------------
# POSTGRESQL (основная база данных)
# Локально: установить PostgreSQL, создать БД content_factory
# На VPS: обычно уже есть, или apt install postgresql
# ------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/content_factory

# Отдельные параметры (если нужны)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=content_factory
DB_USER=postgres
DB_PASSWORD=your_db_password_here


# ------------------------------------------------------------
# REDIS (брокер для очереди задач Celery)
# Локально: установить Redis или запустить через Docker
# На VPS: apt install redis-server
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0


# ------------------------------------------------------------
# НАСТРОЙКИ СИСТЕМЫ
# ------------------------------------------------------------

# Минимальный буфер постов на канал (из handbook: 8 = запас 2 дня)
BUFFER_MIN=8
# Критический уровень (запуск экстренной генерации)
BUFFER_EMERGENCY=4
# Критический уровень (алёрт администратору)
BUFFER_CRITICAL=2

# Задержка публикации после рекламного поста (секунды)
# Случайное значение между MIN и MAX — имитация человека
POST_DELAY_MIN=300    # 5 минут
POST_DELAY_MAX=900    # 15 минут

# Время утренней генерации (по UTC, VPS обычно UTC)
GENERATION_HOUR=3     # 06:00 МСК = 03:00 UTC
GENERATION_MINUTE=0

# Интервал мониторинга каналов (секунды)
MONITOR_INTERVAL=180  # каждые 3 минуты

# Режим отладки (True = подробные логи, False = только важное)
DEBUG=True

# ------------------------------------------------------------
# WILDBERRIES SELLER API (для marketplace-каналов)
# Получить: seller.wildberries.ru → Настройки → Интеграции по API
# Нажми "+ Создать токен", выбери права: ✅ Контент, ✅ Цены и скидки
# Токен длинный, начинается с eyJ...
# ------------------------------------------------------------
WB_API_KEY=

# Режим получения товаров:
#   auto   — сначала пробует Seller API (свои товары), потом поиск по категориям
#   seller — только свои товары (только для продавцов WB)
#   search — поиск по категориям (подходит и для аффилиатов)
WB_API_MODE=auto


# ------------------------------------------------------------
# ПРОКСИ (если Telegram заблокирован провайдером)
# Оставь пустым если VPN включён или прокси не нужен
# Форматы: socks5://user:pass@host:port  или  http://host:port
# ------------------------------------------------------------
PROXY_URL=


# ------------------------------------------------------------
# VPS / ДЕПЛОЙ (для deploy_fixes.py, restore_from_vps.py, ssh_test.py)
# Чтобы IP сервера и пользователь не хранились в коде.
# ------------------------------------------------------------
VPS_HOST=your_vps_ip_here
VPS_USER=root
VPS_KEY=C:\path\to\your\ssh\private_key
