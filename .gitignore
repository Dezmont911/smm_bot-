# ============================================================
# .gitignore — Content Factory Bot
# ============================================================

# --- Секреты (НИКОГДА не коммитить!) ---
.env
*.pem
*.key
*.session
*.session-journal

# --- База данных ---
*.db
*.db-shm
*.db-wal
*.sqlite

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.pyc
.Python
build/
dist/
*.egg-info/
.eggs/

# --- Виртуальное окружение ---
venv/
.venv/
env/
ENV/

# --- Логи ---
logs/
*.log

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# --- Тестовые файлы (временные) ---
test_dedup.py
test_full_cycle.py
test_rss.py

# --- Одноразовые/диагностические скрипты (содержат IP VPS, не часть деплоя) ---
# Локальный тулинг: run_remote_gen.py, диагностика, _*-тесты. В деплой (FILES) не входят.
scripts/

# --- Скриншоты/локальные артефакты разработки ---
screenshots/

# --- Кэш Crawl4AI ---
.crawl4ai/

# Рантайм-настройки админ-панели (machine-specific, не коммитим)
admin_settings.json
